---
import type { Team } from "../../types/team";

interface Props {
    team: Team;
}

const { team } = Astro.props;

const sections = [
    "Historia",
    "Palmarés",
    "Plantillas",
    "Jugadores",
    "Entrenadores",
    "Estadio",
    "Galería"
];
---

<header class="team-header">

    <div class="team-header__logo">

        Escudo

    </div>

    <div class="team-header__info">

        <h1>{team.name}</h1>

        <p>{team.country}</p>

    </div>

</header>

<nav class="team-navigation">

    {
        sections.map(section => (

            <a href={"#" + section.toLowerCase()}>

                {section}

            </a>

        ))
    }

</nav>